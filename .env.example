# Application
NODE_ENV=development
WEB_PORT=3000
API_PORT=3001
API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pyme_financing
POSTGRES_USER=pyme
POSTGRES_PASSWORD=pyme_local_password
DATABASE_URL=postgresql://pyme:pyme_local_password@postgres:5432/pyme_financing?schema=public

# pgAdmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin_local_password

# Auth
JWT_SECRET=change_me_for_local_development
JWT_EXPIRES_IN=1d

# Files
UPLOADS_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
