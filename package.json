{
  "name": "pyme-financing-platform",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:local": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "dev:web": "pnpm --filter @pyme/web dev",
    "dev:api": "pnpm --filter @pyme/api start:dev",
    "prisma:validate": "pnpm --filter @pyme/database prisma:validate",
    "db:generate": "pnpm --filter @pyme/database db:generate",
    "db:migrate": "pnpm --filter @pyme/database db:migrate",
    "db:seed": "pnpm --filter @pyme/database db:seed",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
